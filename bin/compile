#!/bin/bash

set -euo pipefail

# see https://devcenter.heroku.com/articles/buildpack-api#bin-compile
BUILD_DIR=${1:-}
CACHE_DIR=${2:-}

cd "$BUILD_DIR"
mkdir -p "$CACHE_DIR"

FIRA_SANS_VERSION="4.202"
NOTO_EMOJI_VERSION="2.048"

# Helper function to read a tool version from .tool-versions file
# Usage: read_tool_version <tool-name>
read_tool_version() {
    local tool="$1"
    local version
    version=$(grep "^$tool " .tool-versions 2>/dev/null | awk '{print $2}')
    if [ -z "$version" ]; then
        echo "ERROR: Could not find '$tool' version in .tool-versions file" >&2
        exit 1
    fi
    echo "$version"
}

### Setup fonts directory

FONTS_DIR="$BUILD_DIR/.fonts"
mkdir -p "$FONTS_DIR"

# Create fontconfig directory and config
mkdir -p "$BUILD_DIR/.config/fontconfig"
cat > "$BUILD_DIR/.config/fontconfig/fonts.conf" << 'EOF'
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
    <dir>~/.fonts</dir>
</fontconfig>
EOF

### Install fonts for OG image generation

if [ ! -f "$FONTS_DIR/FiraSans-Regular.ttf" ]; then
    echo "-----> Installing Fira Sans font v$FIRA_SANS_VERSION"

    # Download Fira Sans font files
    FIRA_SANS_CACHE="$CACHE_DIR/fira-sans-$FIRA_SANS_VERSION"
    if [ ! -d "$FIRA_SANS_CACHE" ]; then
        mkdir -p "$FIRA_SANS_CACHE"
        # Download from Mozilla's official repository
        curl --fail --proto '=https' --tlsv1.2 --location https://github.com/mozilla/Fira/archive/refs/tags/$FIRA_SANS_VERSION.zip --output "$FIRA_SANS_CACHE/fira-$FIRA_SANS_VERSION.zip"
        unzip -q "$FIRA_SANS_CACHE/fira-$FIRA_SANS_VERSION.zip" -d "$FIRA_SANS_CACHE"
    fi

    # Copy TTF files to user font directory
    cp "$FIRA_SANS_CACHE/Fira-$FIRA_SANS_VERSION/ttf/FiraSans"*.ttf "$FONTS_DIR/"

    # Remove the zip archive to save cache space
    rm -f "$FIRA_SANS_CACHE/fira-$FIRA_SANS_VERSION.zip"
else
    echo "-----> Fira Sans font v$FIRA_SANS_VERSION already installed"
fi

NOTO_CJK_FILE="$FONTS_DIR/NotoSansCJK-Regular.ttc"

if [ ! -f "$NOTO_CJK_FILE" ]; then
    echo "-----> Installing Noto Sans CJK font"
    curl --fail --proto '=https' --tlsv1.2 --location "https://github.com/notofonts/noto-cjk/raw/refs/tags/Sans2.004/Sans/OTC/NotoSansCJK-Regular.ttc" --output "$NOTO_CJK_FILE"
else
    echo "-----> Noto Sans CJK font already installed"
fi

NOTO_EMOJI_FILE="$FONTS_DIR/NotoColorEmoji.ttf"

if [ ! -f "$NOTO_EMOJI_FILE" ]; then
    echo "-----> Installing Noto Color Emoji font v$NOTO_EMOJI_VERSION"
    curl --fail --proto '=https' --tlsv1.2 --location "https://github.com/googlefonts/noto-emoji/raw/refs/tags/v$NOTO_EMOJI_VERSION/fonts/NotoColorEmoji.ttf" --output "$NOTO_EMOJI_FILE"
else
    echo "-----> Noto Color Emoji font v$NOTO_EMOJI_VERSION already installed"
fi

### Install Node.js & pnpm and build frontend

echo "-----> Parsing pnpm version from \`.tool-versions\` file"
PNPM_VERSION="$(read_tool_version pnpm)"
export PNPM_VERSION

export PNPM_HOME="$CACHE_DIR/pnpm"

echo "-----> Installing pnpm v$PNPM_VERSION"
curl -fsSL https://get.pnpm.io/install.sh | ENV="$CACHE_DIR/.shrc" SHELL="$(which sh)" sh -

export PATH="$PNPM_HOME/bin:$PATH"

echo "-----> Parsing Node.js version from \`.tool-versions\` file"
NODE_VERSION="$(read_tool_version nodejs)"

echo "-----> pnpm env use --global $NODE_VERSION"
pnpm env use --global "$NODE_VERSION"

echo "-----> pnpm install"
pnpm install

echo "-----> pnpm run build"
pnpm run build

echo "-----> pnpm run build (Svelte)"
cd "$BUILD_DIR/svelte"
pnpm run build
cd "$BUILD_DIR"

echo "-----> rm -rf node_modules"
rm -rf node_modules

echo "-----> pnpm store prune"
pnpm store prune

### Install Rust and build backend

export RUSTUP_HOME="$CACHE_DIR/rustup"
export CARGO_HOME="$CACHE_DIR/cargo"
export CARGO_TARGET_DIR="$CACHE_DIR/target"

report_cache_sizes() {
  du -sh "$CACHE_DIR" 2>/dev/null || true
  du -sh "$CACHE_DIR/pnpm" 2>/dev/null || true
  du -sh "$CACHE_DIR/rustup" 2>/dev/null || true
  du -sh "$CARGO_HOME/registry/cache" 2>/dev/null || true
  du -sh "$CARGO_HOME/registry/src" 2>/dev/null || true
  du -sh "$CARGO_TARGET_DIR/release/.fingerprint" 2>/dev/null || true
  du -sh "$CARGO_TARGET_DIR/release/build" 2>/dev/null || true
  du -sh "$CARGO_TARGET_DIR/release/deps" 2>/dev/null || true
  du -sh "$CARGO_TARGET_DIR/release/incremental" 2>/dev/null || true
}

if [ ! -x "$CARGO_HOME/bin/rustup" ]; then
    echo "-----> Installing rustup"
    curl --fail --proto '=https' --tlsv1.2 https://sh.rustup.rs | sh -s -- --default-toolchain none -y
else
    echo "-----> rustup already installed"
fi

export PATH="$CARGO_HOME/bin:$PATH"

echo "-----> rustup set profile minimal"
rustup set profile minimal

echo "-----> rustup toolchain install"
rustup toolchain install

echo "-----> cargo build"
cargo build --release

echo "-----> Copying compiled binaries into \`./target/release\` folder"
mkdir -p target/release
find "$CARGO_TARGET_DIR/release" -maxdepth 1 -type f -executable -exec cp -a -t target/release {} \;

echo "-----> Cache size before cleanup"
report_cache_sizes

echo "-----> Cleaning up cache folder"

# Remove rustup toolchains that are not the active one
ACTIVE_TOOLCHAIN=$(rustup show active-toolchain | awk '{print $1}')
rustup toolchain list | while read -r line; do
  toolchain=$(echo "$line" | awk '{print $1}')
  if [ "$toolchain" != "$ACTIVE_TOOLCHAIN" ]; then
    echo "       Removing old toolchain: $toolchain"
    rustup toolchain uninstall "$toolchain"
  fi
done

# Remove rustup download and extraction caches
rm -rf "$RUSTUP_HOME/downloads" "$RUSTUP_HOME/tmp"

# We can remove this completely, as cargo will recreate this from `registry/cache`
rm -rf "$CARGO_HOME/registry/src"

# Remove old .crate files that haven't been used in the past 4 days
if [ -d "$CARGO_HOME/registry/cache" ]; then
  find "$CARGO_HOME/registry/cache" -type f -name "*.crate" -mtime +4 -exec rm -f {} \;
fi

# Remove dependencies that haven't been touched in the past 4 days
if [ -d "$CARGO_TARGET_DIR/release/.fingerprint" ]; then
  find "$CARGO_TARGET_DIR/release/.fingerprint" -maxdepth 1 -type d -mtime +4 -exec rm -rf {} \;
fi
if [ -d "$CARGO_TARGET_DIR/release/build" ]; then
  find "$CARGO_TARGET_DIR/release/build" -maxdepth 1 -type d -mtime +4 -exec rm -rf {} \;
fi
if [ -d "$CARGO_TARGET_DIR/release/deps" ]; then
  find "$CARGO_TARGET_DIR/release/deps" -maxdepth 1 -type f -mtime +4 -exec rm -f {} \;
fi

echo "-----> Cache size after cleanup"
report_cache_sizes
